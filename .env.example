# Root-level example env (copy into each app as needed).
# Do NOT commit real secrets.

# ── Database + Cache ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tracer
REDIS_URL=rediss://:PASSWORD@HOST:6379
REDIS_URL_FILE=
REDIS_TOKEN_FILE=
UPSTASH_REDIS_REST_URL_FILE=
UPSTASH_REDIS_REST_TOKEN_FILE=

# ── Auth (Privy) ─────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Chain selection ──────────────────────────────────────
ACTIVE_CHAIN_ID=84532
NEXT_PUBLIC_ACTIVE_CHAIN_ID=84532

# RPC URLs (set at least the active chain)
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL_FALLBACKS=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
ETHEREUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=

# ── Alchemy (optional enrichment) ─────────────────────────
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_ID=
ALCHEMY_WEBHOOK_AUTH_TOKEN=
ALCHEMY_WEBHOOK_ID_FILE=
ALCHEMY_WEBHOOK_AUTH_TOKEN_FILE=
ENRICHMENT_REQUIRE_WEBHOOK_AUTH=true
ENRICHMENT_MAX_RETRIES=6
ENRICHMENT_RETRY_POLL_MS=5000
ENRICHMENT_QUEUE_ALERT_DEPTH=200

# ── KeeperHub (hackathon focus) ───────────────────────────
KEEPERHUB_API_KEY=

# ── Anchor worker ─────────────────────────────────────────
TRACER_SIGNER_PRIVATE_KEY=
TRACER_SIGNER_PRIVATE_KEY_FILE=
TRACER_ANCHOR_ADDRESS=
ANCHOR_CHAIN_ID=84532
NEXT_PUBLIC_ANCHOR_CHAIN_ID=84532
ANCHOR_MAX_TRACES_PER_TX=50
ANCHOR_MAX_DATA_BYTES=4096
ANCHOR_MAX_GAS_LIMIT=600000
ANCHOR_MAX_RETRIES=6
ANCHOR_QUEUE_ALERT_DEPTH=200

# ── LLM Analysis ──────────────────────────────────────────
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OLLAMA_API_KEY=
OLLAMA_MODEL=
ANALYSIS_MAX_RETRIES=6
ANALYSIS_QUEUE_ALERT_DEPTH=200

# ── Ingest ────────────────────────────────────────────────
TRACER_MASTER_KEY=
INGEST_MAX_BODY_BYTES=10485760
INGEST_RATELIMIT_PER_MIN=10000

# ── Dashboard ─────────────────────────────────────────────
NEXT_PUBLIC_TRACER_INGEST_URL=http://localhost:4001
NEXT_PUBLIC_TRACER_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_TRACER_ENABLE_KEEPERHUB=true
NEXT_PUBLIC_TRACER_ENABLE_OPTIONAL_UNISWAP=false
SERVER_PORT=3001
DASHBOARD_PORT=3000
INGEST_PORT=4001

