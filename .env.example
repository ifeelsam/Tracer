# Root-level example env (copy into each app as needed).
# Do NOT commit real secrets.

# ── Database + Cache ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tracer
REDIS_URL=rediss://:PASSWORD@HOST:6379

# ── Auth (Privy) ─────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Chain selection ──────────────────────────────────────
ACTIVE_CHAIN_ID=84532
NEXT_PUBLIC_ACTIVE_CHAIN_ID=84532

# RPC URLs (set at least the active chain)
BASE_SEPOLIA_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
ETHEREUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=

# ── Alchemy (optional enrichment) ─────────────────────────
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_ID=
ALCHEMY_WEBHOOK_AUTH_TOKEN=

# ── KeeperHub (hackathon focus) ───────────────────────────
KEEPERHUB_API_KEY=

# ── Anchor worker ─────────────────────────────────────────
TRACER_SIGNER_PRIVATE_KEY=
TRACER_ANCHOR_ADDRESS=
ANCHOR_CHAIN_ID=84532
NEXT_PUBLIC_ANCHOR_CHAIN_ID=84532

# ── LLM Analysis ──────────────────────────────────────────
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OLLAMA_API_KEY=
OLLAMA_MODEL=

# ── Ingest ────────────────────────────────────────────────
TRACER_MASTER_KEY=
INGEST_MAX_BODY_BYTES=10485760
INGEST_RATELIMIT_PER_MIN=10000

# ── Dashboard ─────────────────────────────────────────────
NEXT_PUBLIC_TRACER_INGEST_URL=http://localhost:4001
NEXT_PUBLIC_TRACER_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_TRACER_ENABLE_KEEPERHUB=true
NEXT_PUBLIC_TRACER_ENABLE_OPTIONAL_UNISWAP=false

