{
  "name": "tracer",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "postinstall": "pnpm -C packages/db prisma:generate",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:stack": "node scripts/dev-stack.mjs",
    "smoke:stack": "node scripts/smoke-stack.mjs",
    "smoke:staging": "node scripts/smoke-staging.mjs",
    "validate:runtime": "node scripts/assert-runtime-config.mjs",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "turbo": "^2.0.14",
    "typescript": "^5.4.5"
  }
}
