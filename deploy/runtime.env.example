# Runtime port contract (keep deterministic across staging/prod)
SERVER_PORT=3001
DASHBOARD_PORT=3000
INGEST_PORT=4001
ENRICHMENT_PORT=4002

# Dashboard must point to server + ingest runtime ports
NEXT_PUBLIC_TRACER_SERVER_URL=http://server.internal:3001
NEXT_PUBLIC_TRACER_INGEST_URL=http://ingest.internal:4001

# Anchor RPC with fallback provider list
BASE_SEPOLIA_RPC_URL=https://rpc-provider-primary.example
BASE_SEPOLIA_RPC_URL_FALLBACKS=https://rpc-provider-secondary.example,https://rpc-provider-tertiary.example

# Secret files (recommended in production)
TRACER_SIGNER_PRIVATE_KEY_FILE=/run/secrets/tracer_signer_private_key
UPSTASH_REDIS_REST_TOKEN_FILE=/run/secrets/upstash_redis_rest_token
ALCHEMY_WEBHOOK_AUTH_TOKEN_FILE=/run/secrets/alchemy_webhook_auth_token
