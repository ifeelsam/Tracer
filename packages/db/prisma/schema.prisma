/// This schema defines the shared persistence model for Tracer.
/// Start with identities and agent ownership, then layer traces on top.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id
  email         String?
  primaryWallet String?
  createdAt     DateTime     @default(now())
  plan          String       @default("free")
  agents        Agent[]
  agentOwners   AgentOwner[]
}

model Agent {
  id            String       @id
  ownerId       String
  owner         User         @relation(fields: [ownerId], references: [id])
  agentWallet   String?
  displayName   String
  apiKeyHash    String       @unique
  chainId       Int
  environment   String
  privateMode   Boolean      @default(false)
  retentionDays Int          @default(30)
  verifyToken   String       @unique
  verified      Boolean      @default(false)
  verifiedAt    DateTime?
  createdAt     DateTime     @default(now())
  traces        Trace[]
  agentOwners   AgentOwner[]

  @@index([ownerId])
}

model AgentOwner {
  userId String
  agentId String
  role   String
  user   User   @relation(fields: [userId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@id([userId, agentId])
}

model Trace {
  id            String       @id
  agentId       String
  agent         Agent        @relation(fields: [agentId], references: [id])
  chainId       Int
  status        String
  startedAt     DateTime
  endedAt       DateTime?
  durationMs    Int?
  inputSummary  String
  outputSummary String?
  errorMessage  String?
  eventCount    Int          @default(0)
  totalTokens   Int          @default(0)
  totalCostUsd  Decimal      @default(0) @db.Decimal(10, 6)
  totalGasUsed  String       @default("0")
  evmTxCount    Int          @default(0)
  toolsCalled   String[]
  anchorTxHash  String?
  anchorBlock   BigInt?
  merkleProof   String?
  traceHash     String?
  shareToken    String?      @unique
  tags          String[]
  events        TraceEvent[]
  analysis      TraceAnalysis?

  @@index([agentId, startedAt(sort: Desc)])
  @@index([chainId])
  @@index([shareToken])
}

model TraceEvent {
  id               String   @id
  traceId          String
  trace            Trace    @relation(fields: [traceId], references: [id], onDelete: Cascade)
  parentEventId    String?
  sequence         Int
  type             String
  startedAt        DateTime
  endedAt          DateTime?
  durationMs       Int?
  payload          Json
  payloadEncrypted Boolean  @default(false)
  status           String   @default("ok")
  errorMessage     String?

  @@index([traceId, sequence])
  @@index([type])
  @@index([traceId])
}

model TraceAnalysis {
  id              String   @id
  traceId         String   @unique
  trace           Trace    @relation(fields: [traceId], references: [id])
  failureType     String
  confidence      Float
  summary         String
  whatAgentSaw    String
  whatAgentMissed String
  counterfactuals Json
  suggestedFix    String
  analyzedAt      DateTime
  modelUsed       String
  llmProvider     String
}
